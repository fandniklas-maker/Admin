local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- State Variables
local flying = false
local flySpeed = 50
local speedMultiplier = 16
local jumpPower = 50
local commandBarActive = false

-- UI Setup (Command Bar)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AdminCommandBar"
screenGui.ResetOnSpawn = false
screenGui.Parent = game:GetService("CoreGui")

local commandBar = Instance.new("TextBox")
commandBar.Size = UDim2.new(0, 400, 0, 40)
commandBar.Position = UDim2.new(0.5, -200, 0.8, 0)
commandBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
commandBar.TextColor3 = Color3.fromRGB(255, 255, 255)
commandBar.PlaceholderText = "Enter Command (fly, speed [val], jump [val])..."
commandBar.Visible = false
commandBar.Parent = screenGui

-- Fly Logic
local bodyGyro, bodyVelocity
local function toggleFly()
    flying = not flying
    if flying then
        character = player.Character
        local root = character:WaitForChild("HumanoidRootPart")
        
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.P = 9e4
        bodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        bodyGyro.cframe = root.CFrame
        bodyGyro.Parent = root
        
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.velocity = Vector3.new(0, 0, 0)
        bodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
        bodyVelocity.Parent = root
        
        humanoid.PlatformStand = true
        
        task.spawn(function()
            while flying do
                local camera = workspace.CurrentCamera
                local moveDir = humanoid.MoveDirection
                
                if moveDir.Magnitude > 0 then
                    bodyVelocity.velocity = camera.CFrame.LookVector * flySpeed
                else
                    bodyVelocity.velocity = Vector3.new(0, 0, 0)
                end
                
                bodyGyro.cframe = camera.CFrame
                RunService.RenderStepped:Wait()
            end
        end)
    else
        if bodyGyro then bodyGyro:Destroy() end
        if bodyVelocity then bodyVelocity:Destroy() end
        humanoid.PlatformStand = false
    end
end

-- Command Processor
local function executeCommand(input)
    local args = string.split(string.lower(input), " ")
    local cmd = args[1]
    
    if cmd == "fly" then
        toggleFly()
    elseif cmd == "speed" then
        local val = tonumber(args[2]) or 16
        humanoid.WalkSpeed = val
    elseif cmd == "jump" then
        local val = tonumber(args[2]) or 50
        humanoid.JumpPower = val
        humanoid.UseJumpPower = true
    end
end

-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Open Command Bar with Right Control
    if input.KeyCode == Enum.KeyCode.RightControl then
        commandBarActive = not commandBarActive
        commandBar.Visible = commandBarActive
        if commandBarActive then
            commandBar:CaptureFocus()
        else
            commandBar:ReleaseFocus()
        end
    end
end)

commandBar.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        executeCommand(commandBar.Text)
        commandBar.Text = ""
    end
    commandBar.Visible = false
    commandBarActive = false
end)

-- Update character reference on respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    flying = false
end)
