-- Logic Functions
local flying = false
local noclip = false

local function setMoney(amount)
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        for _, val in pairs(stats:GetChildren()) do
            local name = val.Name:lower()
            if name == "money" or name == "cash" or name == "geld" or name == "coins" or name == "currency" then
                val.Value = amount
            end
        end
    end
end

local function runCommand(input)
    local args = string.split(input, " ")
    local cmd = args[1]:lower()

    if cmd == "/speed" or cmd == "/ws" then
        local power = tonumber(args[2]) or 16
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = power
        end
    elseif cmd == "/jumppower" or cmd == "/jp" then
        local power = tonumber(args[2]) or 50
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.UseJumpPower = true
            player.Character.Humanoid.JumpPower = power
        end
    elseif cmd == "/money" or cmd == "/cash" or cmd == "/geld" then
        local amount = tonumber(args[2]) or 999999
        setMoney(amount)
    elseif cmd == "/cmds" then
        helpMenu.Visible = not helpMenu.Visible
    elseif cmd == "/re" then
        if player.Character then player.Character:BreakJoints() end
    elseif cmd == "/exit" then
        helpMenu.Visible = false
    elseif cmd == "/noclip" then
        noclip = not noclip
    end
end

-- Input Handling
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    -- Toggle Command Bar with Left Control (Strg)
    if input.KeyCode == Enum.KeyCode.LeftControl then
        commandBarActive = not commandBarActive
        cmdBar.Visible = commandBarActive
        if commandBarActive then
            cmdBar:CaptureFocus()
            cmdBar:TweenPosition(UDim2.new(0.5, -200, 0, 50), "Out", "Quad", 0.3, true)
        else
            cmdBar:ReleaseFocus()
            cmdBar:TweenPosition(UDim2.new(0.5, -200, 0, -50), "In", "Quad", 0.3, true)
        end
    end
end)

cmdBar.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        runCommand(cmdBar.Text)
    end
    cmdBar.Text = ""
    commandBarActive = false
    cmdBar:TweenPosition(UDim2.new(0.5, -200, 0, -50), "In", "Quad", 0.3, true, function()
        cmdBar.Visible = false
    end)
end)

player.Chatted:Connect(function(msg)
    if msg:sub(1,1) == prefix then
        runCommand(msg)
    end
end)

-- NoClip Loop
RunService.Stepped:Connect(function()
    if noclip and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)
