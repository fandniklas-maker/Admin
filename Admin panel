local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/78n/Example/main/SimpleGuiLib.lua"))()
local Window = Library.CreateLib("Admin Panel", "Default")

local Tab = Window:NewTab("Main")
local Section = Tab:NewSection("Movement")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local settings = {
    flySpeed = 50,
    walkSpeed = 16,
    jumpPower = 50,
    infJump = false,
    flying = false
}

-- WalkSpeed
Section:NewSlider("WalkSpeed", "Changes player speed", 250, 16, function(s)
    settings.walkSpeed = s
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = s
    end
end)

-- Infinite Jump
Section:NewToggle("Infinite Jump", "Jump as many times as you want", function(state)
    settings.infJump = state
end)

UserInputService.JumpRequest:Connect(function()
    if settings.infJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- Fly Logic
local flyPart
Section:NewToggle("Fly", "Toggle flight mode", function(state)
    settings.flying = state
    
    if state then
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        
        flyPart = Instance.new("BodyVelocity")
        flyPart.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        flyPart.Velocity = Vector3.new(0, 0, 0)
        flyPart.Parent = char.HumanoidRootPart
        
        local bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 9e4
        bg.CFrame = char.HumanoidRootPart.CFrame
        bg.Parent = char.HumanoidRootPart
        
        task.spawn(function()
            while settings.flying and char:FindFirstChild("HumanoidRootPart") do
                local camera = workspace.CurrentCamera
                local moveDir = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
                
                flyPart.Velocity = moveDir * settings.flySpeed
                bg.CFrame = camera.CFrame
                RunService.RenderStepped:Wait()
            end
            if flyPart then flyPart:Destroy() end
            if bg then bg:Destroy() end
        end)
    end
end)

Section:NewSlider("Fly Speed", "Speed of flight", 300, 10, function(s)
    settings.flySpeed = s
end)

-- Reset on respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid").WalkSpeed = settings.walkSpeed
end)
