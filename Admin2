local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer
local Prefix = "/"
local CommandBarKey = Enum.KeyCode.LeftControl

-- UI Creation
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AdminCommandGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = game:GetService("CoreGui")

local TextBox = Instance.new("TextBox")
TextBox.Name = "CommandBar"
TextBox.Size = UDim2.new(0, 400, 0, 40)
TextBox.Position = UDim2.new(0.5, -200, 1, -100)
TextBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
TextBox.PlaceholderText = "Enter command here..."
TextBox.Visible = false
TextBox.BorderSizePixel = 2
TextBox.BorderColor3 = Color3.fromRGB(0, 170, 255)
TextBox.Font = Enum.Font.Code
TextBox.TextSize = 18
TextBox.Parent = ScreenGui

-- Utility Functions
local function Notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title;
        Text = text;
        Duration = 5;
    })
end

local function GetPlayer(name)
    name = name:lower()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Name:lower():sub(1, #name) == name or player.DisplayName:lower():sub(1, #name) == name then
            return player
        end
    end
    return nil
end

-- Command Logic
local Commands = {}

Commands.money = function(args)
    local target = GetPlayer(args[1] or "") or LocalPlayer
    local amount = tonumber(args[2]) or 0
    
    -- Note: This attempts to find common leaderstat names
    local stats = target:FindFirstChild("leaderstats") or target:FindFirstChild("Data")
    if stats then
        local money = stats:FindFirstChild("Money") or stats:FindFirstChild("Cash") or stats:FindFirstChild("Coins") or stats:FindFirstChild("Credits")
        if money and money:IsA("NumberValue") or money:IsA("IntValue") then
            money.Value = amount
            Notify("Success", "Set " .. target.Name .. "'s money to " .. amount)
        else
            Notify("Error", "Could not find Money value in leaderstats")
        end
    else
        Notify("Error", "Player has no leaderstats folder")
    end
end

Commands.speed = function(args)
    local target = GetPlayer(args[1] or "") or LocalPlayer
    local speed = tonumber(args[2]) or 16
    if target.Character and target.Character:FindFirstChild("Humanoid") then
        target.Character.Humanoid.WalkSpeed = speed
        Notify("Success", "Speed set to " .. speed)
    end
end

Commands.jump = function(args)
    local target = GetPlayer(args[1] or "") or LocalPlayer
    local power = tonumber(args[2]) or 50
    if target.Character and target.Character:FindFirstChild("Humanoid") then
        target.Character.Humanoid.JumpPower = power
        Notify("Success", "JumpPower set to " .. power)
    end
end

Commands.tp = function(args)
    local target1 = GetPlayer(args[1] or "")
    local target2 = GetPlayer(args[2] or "")
    if target1 and target2 and target1.Character and target2.Character then
        target1.Character:MoveTo(target2.Character.PrimaryPart.Position)
    end
end

-- Execution
local function ExecuteCommand(input)
    if input:sub(1, #Prefix) == Prefix then
        input = input:sub(#Prefix + 1)
    end
    
    local args = input:split(" ")
    local cmdName = table.remove(args, 1):lower()
    
    if Commands[cmdName] then
        local success, err = pcall(function()
            Commands[cmdName](args)
        end)
        if not success then
            warn("Command Error: " .. err)
        end
    else
        Notify("Error", "Unknown Command: " .. cmdName)
    end
end

-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == CommandBarKey then
        TextBox.Visible = not TextBox.Visible
        if TextBox.Visible then
            TextBox:CaptureFocus()
        end
    end
end)

TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local text = TextBox.Text
        if text ~= "" then
            ExecuteCommand(text)
        end
    end
    TextBox.Visible = false
    TextBox.Text = ""
end)

Notify("Admin Loaded", "Press Ctrl to open Command Bar. Prefix: " .. Prefix)
