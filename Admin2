-- Helper function to find players
local function getPlayer(name)
    name = name:lower()
    if name == "me" then return {LocalPlayer} end
    if name == "all" then return Players:GetPlayers() end
    if name == "others" then
        local list = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(list, p) end
        end
        return list
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name then
            return {p}
        end
    end
    return {}
end

-- Command Logic
local Commands = {}

Commands.money = function(args)
    local targetPlayers = getPlayer(args[1] or "me")
    local amount = tonumber(args[2]) or 0
    
    for _, p in pairs(targetPlayers) do
        -- Common leaderstat names
        local stats = p:FindFirstChild("leaderstats")
        if stats then
            for _, stat in pairs(stats:GetChildren()) do
                if stat:IsA("NumberValue") or stat:IsA("IntValue") then
                    if stat.Name:lower():find("money") or stat.Name:lower():find("cash") or stat.Name:lower():find("coins") then
                        stat.Value = amount
                    end
                end
            end
        end
    end
end

Commands.speed = function(args)
    local targetPlayers = getPlayer(args[1] or "me")
    local speed = tonumber(args[2]) or 16
    for _, p in pairs(targetPlayers) do
        if p.Character and p.Character:FindFirstChild("Humanoid") then
            p.Character.Humanoid.WalkSpeed = speed
        end
    end
end

Commands.jump = function(args)
    local targetPlayers = getPlayer(args[1] or "me")
    local power = tonumber(args[2]) or 50
    for _, p in pairs(targetPlayers) do
        if p.Character and p.Character:FindFirstChild("Humanoid") then
            p.Character.Humanoid.JumpPower = power
        end
    end
end

Commands.kill = function(args)
    local targetPlayers = getPlayer(args[1])
    for _, p in pairs(targetPlayers) do
        if p.Character and p.Character:FindFirstChild("Humanoid") then
            p.Character.Humanoid.Health = 0
        end
    end
end

-- Execution Logic
local function executeCommand(input)
    local split = input:split(" ")
    local cmdName = split[1]:lower()
    local args = {}
    for i = 2, #split do
        table.insert(args, split[i])
    end

    if Commands[cmdName] then
        local success, err = pcall(function()
            Commands[cmdName](args)
        end)
        if not success then
            warn("Command Error: " .. err)
        end
    end
end

-- Input Handling
CommandBar.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        executeCommand(CommandBar.Text)
    end
    CommandBar.Visible = false
    CommandBar.Text = ""
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- "Strg" is Ctrl. Using LeftControl or RightControl
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        CommandBar.Visible = not CommandBar.Visible
        if CommandBar.Visible then
            CommandBar:CaptureFocus()
            -- Small delay to prevent the key press from typing into the box
            task.wait()
            CommandBar.Text = ""
        end
    end
end)

-- Chat listener for standard prefix commands
LocalPlayer.Chatted:Connect(function(msg)
    if msg:sub(1, 1) == Prefix then
        executeCommand(msg:sub(2))
    end
end)

print("Admin System Loaded. Press Ctrl to open Command Bar.")
