-- Logic and Commands
local commands = {}

local function addCommand(name, aliases, desc, callback)
    commands[name] = {aliases = aliases, desc = desc, callback = callback}
    
    local cmdLabel = Instance.new("TextLabel")
    cmdLabel.Size = UDim2.new(1, 0, 0, 30)
    cmdLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    cmdLabel.Font = Enum.Font.Gotham
    cmdLabel.Text = " " .. prefix .. name .. " - " .. desc
    cmdLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    cmdLabel.TextSize = 14
    cmdLabel.TextXAlignment = Enum.TextXAlignment.Left
    cmdLabel.Parent = ScrollingFrame
    
    local UICorner_Label = Instance.new("UICorner")
    UICorner_Label.CornerRadius = UDim.new(0, 4)
    UICorner_Label.Parent = cmdLabel
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end

local function runCommand(input)
    local args = input:split(" ")
    local cmdName = args[1]:lower():gsub(prefix, "")
    table.remove(args, 1)

    for name, data in pairs(commands) do
        local isAlias = false
        for _, alias in ipairs(data.aliases) do
            if alias:lower() == cmdName then isAlias = true break end
        end

        if name:lower() == cmdName or isAlias then
            data.callback(args)
            return
        end
    end
end

-- Registering Commands
addCommand("speed", {"ws", "walkspeed"}, "Set character speed", function(args)
    local speed = tonumber(args[1]) or 16
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = speed
    end
end)

addCommand("jump", {"jp", "jumppower"}, "Set jump power", function(args)
    local jp = tonumber(args[1]) or 50
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.UseJumpPower = true
        player.Character.Humanoid.JumpPower = jp
    end
end)

addCommand("money", {"cash", "geld", "currency"}, "Set local money (Visual/Leaderstats)", function(args)
    local amount = tonumber(args[1]) or 0
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        for _, v in ipairs(stats:GetChildren()) do
            local n = v.Name:lower()
            if n:find("money") or n:find("cash") or n:find("geld") or n:find("coins") then
                v.Value = amount
            end
        end
    end
end)

addCommand("cmds", {"help", "menu"}, "Open command list", function()
    MenuFrame.Visible = not MenuFrame.Visible
end)

addCommand("exit", {"close"}, "Close the menu", function()
    MenuFrame.Visible = false
end)

-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Semicolon or input.KeyCode == Enum.KeyCode.Slash then
        CommandBarFrame.Visible = true
        TextBox:CaptureFocus()
        task.wait()
        TextBox.Text = ""
    end
end)

TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local text = TextBox.Text
        if text ~= "" then
            runCommand(text)
        end
    end
    CommandBarFrame.Visible = false
    TextBox.Text = ""
end)

player.Chatted:Connect(function(msg)
    if msg:sub(1, #prefix) == prefix then
        runCommand(msg)
    end
end)
