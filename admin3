local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "OP Executor Hub | Universal",
   LoadingTitle = "Loading Ultimate Suite...",
   LoadingSubtitle = "by Helpful AI",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "OP_Hub_Config",
      FileName = "UniversalConfig"
   },
   KeySystem = false
})

-- Variables
local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

local ESPEnabled = false
local TracersEnabled = false
local FlyEnabled = false
local FlySpeed = 50

-- Tabs
local MainTab = Window:CreateTab("Main", 4483362458)
local PlayerTab = Window:CreateTab("Player", 4483362458)
local VisualsTab = Window:CreateTab("Visuals", 4483362458)
local ScriptsTab = Window:CreateTab("Scripts", 4483362458)

-- Main Tab
MainTab:CreateSection("Universal Utilities")

MainTab:CreateButton({
   Name = "Infinite Yield",
   Callback = function()
       loadstring(game:HttpGet('https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source'))()
   end,
})

MainTab:CreateButton({
   Name = "Dex Explorer",
   Callback = function()
       loadstring(game:HttpGet("https://raw.githubusercontent.com/infyiff/backup/main/dex.lua"))()
   end,
})

-- Player Tab
PlayerTab:CreateSection("Movement")

PlayerTab:CreateSlider({
   Name = "WalkSpeed",
   Range = {16, 500},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Flag = "WS_Slider",
   Callback = function(Value)
       Humanoid.WalkSpeed = Value
   end,
})

PlayerTab:CreateSlider({
   Name = "JumpPower",
   Range = {50, 500},
   Increment = 1,
   Suffix = "Power",
   CurrentValue = 50,
   Flag = "JP_Slider",
   Callback = function(Value)
       Humanoid.UseJumpPower = true
       Humanoid.JumpPower = Value
   end,
})

PlayerTab:CreateToggle({
   Name = "Fly",
   CurrentValue = false,
   Flag = "Fly_Toggle",
   Callback = function(Value)
       FlyEnabled = Value
       if FlyEnabled then
           local BodyGyro = Instance.new("BodyGyro", Character.PrimaryPart)
           local BodyVelocity = Instance.new("BodyVelocity", Character.PrimaryPart)
           BodyGyro.P = 9e4
           BodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
           BodyGyro.cframe = Character.PrimaryPart.CFrame
           BodyVelocity.velocity = Vector3.new(0, 0.1, 0)
           BodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
           
           task.spawn(function()
               while FlyEnabled do
                   local Camera = workspace.CurrentCamera
                   BodyVelocity.velocity = ((Camera.CFrame.LookVector * (FlySpeed)) + (Camera.CFrame.RightVector * 0))
                   BodyGyro.cframe = Camera.CFrame
                   task.wait()
               end
               BodyGyro:Destroy()
               BodyVelocity:Destroy()
           end)
       end
   end,
})

-- Visuals Tab
VisualsTab:CreateSection("ESP")

VisualsTab:CreateToggle({
   Name = "Enable ESP Boxes",
   CurrentValue = false,
   Flag = "ESP_Toggle",
   Callback = function(Value)
       ESPEnabled = Value
       if ESPEnabled then
           task.spawn(function()
               while ESPEnabled do
                   for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                       if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                           if not v.Character:FindFirstChild("Highlight") then
                               local Highlight = Instance.new("Highlight", v.Character)
                               Highlight.FillTransparency = 0.5
                               Highlight.OutlineTransparency = 0
                               Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                           end
                       end
                   end
                   task.wait(1)
               end
               for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                   if v.Character and v.Character:FindFirstChild("Highlight") then
                       v.Character.Highlight:Destroy()
                   end
               end
           end)
       end
   end,
})

